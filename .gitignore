# Root gitignore for monorepo

# OS
.DS_Store
Thumbs.db

# Editor / IDE
.idea/
.vscode/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Python / backend
backend/.env
backend/.env.*
__pycache__/
*.py[cod]
*.pyo
.venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Node / frontend
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

.next/
out/
build/
.turbo/
.vercel/
*.tsbuildinfo

# Misc
*.pem
